{
  "name": "agtps-portal",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web": "npm --workspace apps/web run dev",
    "api": "npm --workspace apps/api run start:dev",
    "build": "npm run build --workspaces",
