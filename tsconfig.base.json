{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,

    "resolveJsonModule": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "allowSyntheticDefaultImports": true,

    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",

    "paths": {
      "@shared/*": [
        "packages/shared/*"
      ],
      "@types/*": [
        "packages/types/*"
      ],
      "@ui/*": [
        "packages/ui/*"
      ],
      "@config/*": [
        "packages/config/*"
      ]
    }
  }
}
