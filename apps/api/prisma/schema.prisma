generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  ACTIVE
  MAINTENANCE
  OFFLINE
  DISABLED
}

enum NetworkType {
  INTERNET
  INTRANET
  VPN
}

enum MeetingStatus {
  SCHEDULED
  CANCELLED
  DONE
}

enum MeetingVisibility {
  PUBLIC
  PRIVATE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum NotificationType {
  ANNOUNCEMENT
  DIRECT_MESSAGE
  MEETING_INVITE
  MEETING_UPDATE
  REMINDER
  TASK
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  USER_UPDATED
  PASSWORD_CHANGED
  BACKUP_CREATED
  BACKUP_DELETED
  BACKUP_RESTORED
  NOTIFICATION_RULE_UPDATED
  DIRECT_MANAGER_CREATED
  DIRECT_MANAGER_UPDATED
  DIRECT_MANAGER_DELETED
  FORBIDDEN_WORD_CREATED
  FORBIDDEN_WORD_UPDATED
  FORBIDDEN_WORD_DELETED
  DIRECT_CONVERSATION_CREATED
  DIRECT_CONVERSATION_OPENED
  DIRECT_CONVERSATION_REPLIED
  DIRECT_CONVERSATION_STATUS_CHANGED
}

enum DirectCommunicationMode {
  NORMAL
  CONFIDENTIAL
  ANONYMOUS
}

enum DirectCommunicationCategory {
  SUGGESTION
  COMPLAINT
  VIOLATION_REPORT
  IMPROVEMENT_IDEA
  REQUEST
  CONFIDENTIAL_REPORT
  GENERAL_MESSAGE
}

enum DirectCommunicationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum DirectCommunicationStatus {
  OPEN
  RESOLVED
  ARCHIVED
  CLOSED
}

enum DirectCommunicationSenderType {
  EMPLOYEE
  MANAGER
  SYSTEM
}

enum DirectorySource {
  INTERNAL
  ACTIVE_DIRECTORY
}

enum TrainingContentType {
  VIDEO
  PDF
  DOCUMENT
  SPREADSHEET
  PRESENTATION
  IMAGE
  LINK
  ATTACHMENT
}

enum TrainingPublishStatus {
  NEEDS_REVIEW
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TrainingProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum InPersonTrainingStatus {
  PLANNED
  OPEN
  CLOSED
  CANCELLED
  COMPLETED
}

enum InPersonAttendanceStatus {
  REGISTERED
  ATTENDED
  ABSENT
  EXCUSED
}

enum InPersonTrainingResult {
  PASSED
  FAILED
  NO_EXAM
}

enum PollSurveyType {
  POLL
  SURVEY
}

enum PollSurveyStatus {
  DRAFT
  SCHEDULED
  RUNNING
  CLOSED
  ARCHIVED
}

enum PollSurveyQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TEXT
  PARAGRAPH
  RATING
  YES_NO
  NUMBER
  DATE
  MATRIX
}

enum PollSurveyResponseStatus {
  DRAFT
  SUBMITTED
}

enum PollSurveyParticipationMode {
  IDENTIFIED
  ANONYMOUS_TRACKED
  ANONYMOUS_FULL
}

model User {
  id       String @id @default(cuid())
  username String @unique
  email    String @unique
  password String

  firstName           String?
  lastName            String?
  personnelCode       String?
  birthDate           DateTime?
  mobile              String?
  allowEmailChange    Boolean   @default(false)
  allowPasswordChange Boolean   @default(true)
  allowProfileEdit    Boolean   @default(true)

  isActive Boolean @default(true)

  directoryUserId String?        @unique
  directoryUser   DirectoryUser? @relation(fields: [directoryUserId], references: [id], onDelete: SetNull)

  roles                            UserRole[]
  organizedMeetings                Meeting[]                         @relation("MeetingOrganizer")
  meetingParticipants              MeetingParticipant[]
  notes                            PortalNote[]
  reminders                        PortalReminder[]
  tasks                            PortalTask[]
  downloads                        PortalDownload[]
  trainingProgress                 TrainingProgress[]
  inPersonTrainingParticipants     InPersonTrainingParticipant[]
  createdPollSurveys               PollSurvey[]                      @relation("PollSurveyCreator")
  pollSurveyResponses              PollSurveyResponse[]
  pollSurveyParticipations         PollSurveyParticipation[]
  smbAudits                        SmbFileAudit[]
  auditLogs                        AuditLog[]
  directCommunicationManagers      DirectCommunicationManager[]
  directCommunicationConversations DirectCommunicationConversation[]
  directCommunicationMessages      DirectCommunicationMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id    String @id @default(cuid())
  name  String @unique
  title String

  users           UserRole[]
  permissions     RolePermission[]
  directoryGroups DirectoryGroupRole[]

  createdAt DateTime @default(now())
}

model Permission {
  id    String @id @default(cuid())
  name  String @unique
  title String

  roles RolePermission[]
}

model AuditLog {
  id String @id @default(cuid())

  actorUserId   String?
  actorUsername String?
  actorEmail    String?

  action     AuditAction
  entityType String
  entityId   String?
  summary    String?
  metadata   Json?

  ipAddress String?
  userAgent String? @db.Text

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model DirectoryUser {
  id          String          @id @default(cuid())
  username    String          @unique
  displayName String
  email       String?
  mobile      String?
  department  String?
  title       String?
  source      DirectorySource @default(INTERNAL)
  isActive    Boolean         @default(true)
  externalId        String?  @unique
  distinguishedName String?
  lastSyncedAt      DateTime?
  portalUser        User?

  groupMemberships                 DirectoryGroupMember[]
  organizedMeetings                Meeting[]                         @relation("DirectoryMeetingOrganizer")
  meetingParticipants              MeetingParticipant[]
  notifications                    PortalNotification[]
  pushSubscriptions                PushSubscription[]
  trainingProgress                 TrainingProgress[]
  inPersonTrainingParticipants     InPersonTrainingParticipant[]
  pollSurveyResponses              PollSurveyResponse[]
  pollSurveyParticipations         PollSurveyParticipation[]
  smbShareAccesses                 SmbShareUserAccess[]
  directCommunicationManagers      DirectCommunicationManager[]
  directCommunicationConversations DirectCommunicationConversation[]
  directCommunicationMessages      DirectCommunicationMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source, isActive])
}

model DirectCommunicationManager {
  id String @id @default(cuid())

  title       String
  department  String?
  description String? @db.Text
  isCeo       Boolean @default(false)
  isActive    Boolean @default(true)

  portalUserId    String?
  directoryUserId String?

  portalUser    User?                             @relation(fields: [portalUserId], references: [id], onDelete: SetNull)
  directoryUser DirectoryUser?                    @relation(fields: [directoryUserId], references: [id], onDelete: SetNull)
  conversations DirectCommunicationConversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isCeo])
  @@index([isActive])
}

model DirectCommunicationConversation {
  id String @id @default(cuid())

  managerId String
  manager   DirectCommunicationManager @relation(fields: [managerId], references: [id], onDelete: Restrict)

  mode     DirectCommunicationMode     @default(NORMAL)
  category DirectCommunicationCategory @default(GENERAL_MESSAGE)
  priority DirectCommunicationPriority @default(NORMAL)
  status   DirectCommunicationStatus   @default(OPEN)

  subject            String
  tags               String[] @default([])
  anonymousTokenHash String?  @unique

  senderUserId          String?
  senderDirectoryUserId String?
  senderDisplayName     String?

  senderUser          User?          @relation(fields: [senderUserId], references: [id], onDelete: SetNull)
  senderDirectoryUser DirectoryUser? @relation(fields: [senderDirectoryUserId], references: [id], onDelete: SetNull)

  isReadByManager Boolean   @default(false)
  lastMessageAt   DateTime?

  messages DirectCommunicationMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([managerId])
  @@index([mode])
  @@index([category])
  @@index([priority])
  @@index([status])
  @@index([createdAt])
}

model DirectCommunicationMessage {
  id String @id @default(cuid())

  conversationId String
  conversation   DirectCommunicationConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderType            DirectCommunicationSenderType
  senderUserId          String?
  senderDirectoryUserId String?

  senderUser          User?          @relation(fields: [senderUserId], references: [id], onDelete: SetNull)
  senderDirectoryUser DirectoryUser? @relation(fields: [senderDirectoryUserId], references: [id], onDelete: SetNull)

  encryptedPayload  String @db.Text
  encryptionVersion String @default("placeholder-v1")
  attachments       Json?

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([senderType])
  @@index([createdAt])
}

model DirectCommunicationForbiddenWord {
  id String @id @default(cuid())

  word           String
  normalizedWord String
  description    String? @db.Text
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([normalizedWord])
  @@index([isActive])
}

model DirectoryGroup {
  id          String          @id @default(cuid())
  name        String          @unique
  title       String
  description String?
  source      DirectorySource @default(INTERNAL)
  isActive    Boolean         @default(true)
  externalId        String?  @unique
  distinguishedName String?
  lastSyncedAt      DateTime?

  members          DirectoryGroupMember[]
  roles            DirectoryGroupRole[]
  smbShareAccesses SmbShareGroupAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source, isActive])
}

model DirectoryGroupMember {
  groupId String
  userId  String

  group DirectoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  DirectoryUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

model DirectoryGroupRole {
  groupId String
  roleId  String

  group DirectoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role  Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([groupId, roleId])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Site {
  id   String @id @default(cuid())
  code String @unique
  name String

  description String?
  baseUrl     String?
  ipRange     String?
  address     String?
  phone       String?
  email       String?

  latitude  Float?
  longitude Float?

  logo  String?
  image String?
  color String?

  sortOrder Int @default(0)

  isActive Boolean @default(true)

  applicationSites ApplicationSite[]
  news             News[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApplicationCategory {
  id String @id @default(cuid())

  name String
  slug String @unique

  icon        String?
  color       String?
  description String?

  sortOrder Int @default(0)

  isActive Boolean @default(true)

  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Application {
  id String @id @default(cuid())

  key  String @unique
  slug String @unique

  title       String
  description String?

  icon String?

  color String?

  status ApplicationStatus @default(ACTIVE)

  networkType NetworkType @default(INTRANET)

  version String?

  owner String?

  supportDepartment String?

  guideUrl String?

  isFeatured Boolean @default(false)

  isNew Boolean @default(false)

  openInNewTab Boolean @default(true)

  sortOrder Int @default(0)

  isActive Boolean @default(true)

  categoryId String
  category   ApplicationCategory @relation(fields: [categoryId], references: [id])

  sites ApplicationSite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApplicationSite {
  id String @id @default(cuid())

  applicationId String
  siteId        String

  url String

  isActive Boolean @default(true)

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([applicationId, siteId])
}

model News {
  id            String  @id @default(cuid())
  title         String
  body          String  @db.Text
  category      String?
  attachmentUrl String?
  image         String?
  published     Boolean @default(true)

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Announcement {
  id            String  @id @default(cuid())
  title         String
  body          String  @db.Text
  category      String?
  attachmentUrl String?

  startDate DateTime
  endDate   DateTime?

  priority Int @default(1)

  published Boolean @default(true)

  createdAt DateTime @default(now())
}

model Meeting {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text
  location    String?

  startAt DateTime
  endAt   DateTime?

  status      MeetingStatus     @default(SCHEDULED)
  visibility  MeetingVisibility @default(PUBLIC)
  isPublished Boolean           @default(true)

  organizerId              String?
  organizer                User?          @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)
  organizerDirectoryUserId String?
  organizerDirectoryUser   DirectoryUser? @relation("DirectoryMeetingOrganizer", fields: [organizerDirectoryUserId], references: [id], onDelete: SetNull)

  participants  MeetingParticipant[]
  notifications PortalNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MeetingParticipant {
  id              String  @id @default(cuid())
  meetingId       String
  userId          String?
  directoryUserId String?

  displayName String
  email       String?

  notificationSent Boolean @default(false)
  responseStatus   String?

  meeting       Meeting        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  directoryUser DirectoryUser? @relation(fields: [directoryUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model PortalNotification {
  id    String           @id @default(cuid())
  type  NotificationType
  title String
  body  String?          @db.Text

  recipientDirectoryUserId String?
  recipientEmail           String?

  meetingId   String?
  reminderId  String?
  taskId      String?
  scheduledAt DateTime?
  sentAt      DateTime?
  readAt      DateTime?

  recipientDirectoryUser DirectoryUser?  @relation(fields: [recipientDirectoryUserId], references: [id], onDelete: SetNull)
  meeting                Meeting?        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  reminder               PortalReminder? @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  task                   PortalTask?     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String  @id @default(cuid())
  endpoint  String  @unique @db.Text
  p256dh    String
  auth      String
  userAgent String?

  recipientDirectoryUserId String?
  recipientEmail           String?

  recipientDirectoryUser DirectoryUser? @relation(fields: [recipientDirectoryUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortalNote {
  id       String  @id @default(cuid())
  ownerId  String?
  title    String
  body     String  @db.Text
  color    String?
  isPinned Boolean @default(false)

  owner User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortalReminder {
  id                  String   @id @default(cuid())
  ownerId             String?
  title               String
  description         String?  @db.Text
  remindAt            DateTime
  notifyBeforeMinutes Int?
  completed           Boolean  @default(false)

  owner         User?                @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  notifications PortalNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortalTask {
  id                  String     @id @default(cuid())
  ownerId             String?
  title               String
  description         String?    @db.Text
  dueDate             DateTime?
  notifyBeforeMinutes Int?
  status              TaskStatus @default(TODO)
  priority            Int        @default(1)

  owner         User?                @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  notifications PortalNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortalDownload {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text
  version     String?
  fileUrl     String
  category    String?
  icon        String?
  color       String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortalModule {
  id String @id @default(cuid())

  key         String  @unique
  title       String
  description String? @db.Text

  icon       String?
  route      String?
  permission String?

  isCore      Boolean @default(false)
  isInstalled Boolean @default(true)
  isEnabled   Boolean @default(true)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SmbShare {
  id String @id @default(cuid())

  key         String  @unique
  title       String
  description String? @db.Text
  rootPath    String
  uncPath     String?
  authMode   String  @default("KERBEROS")
  realm      String?
  sharedUsername String?
  sharedPassword String?
  lastConnectionAt DateTime?
  lastConnectionStatus String?
  lastConnectionError String? @db.Text
  icon        String?
  color       String?

  allowDownload Boolean @default(true)
  allowUpload   Boolean @default(false)
  allowDelete   Boolean @default(false)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  userAccesses  SmbShareUserAccess[]
  groupAccesses SmbShareGroupAccess[]
  audits        SmbFileAudit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SmbShareUserAccess {
  shareId         String
  directoryUserId String

  canRead     Boolean @default(true)
  canDownload Boolean @default(true)
  canUpload   Boolean @default(false)
  canDelete   Boolean @default(false)

  share SmbShare      @relation(fields: [shareId], references: [id], onDelete: Cascade)
  user  DirectoryUser @relation(fields: [directoryUserId], references: [id], onDelete: Cascade)

  @@id([shareId, directoryUserId])
}

model SmbShareGroupAccess {
  shareId          String
  directoryGroupId String

  canRead     Boolean @default(true)
  canDownload Boolean @default(true)
  canUpload   Boolean @default(false)
  canDelete   Boolean @default(false)

  share SmbShare       @relation(fields: [shareId], references: [id], onDelete: Cascade)
  group DirectoryGroup @relation(fields: [directoryGroupId], references: [id], onDelete: Cascade)

  @@id([shareId, directoryGroupId])
}

model SmbFileAudit {
  id String @id @default(cuid())

  shareId String
  userId  String?

  action SmbFileAuditAction
  path   String
  detail String?            @db.Text

  share SmbShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  user  User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

enum SmbFileAuditAction {
  LIST
  PREVIEW
  DOWNLOAD
  UPLOAD
  DELETE
}

model TrainingCategory {
  id String @id @default(cuid())

  name        String
  slug        String  @unique
  description String? @db.Text
  color       String?
  icon        String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  trainings         TrainingItem[]
  inPersonTrainings InPersonTraining[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainingItem {
  id String @id @default(cuid())

  title       String
  slug        String  @unique
  description String? @db.Text

  contentType TrainingContentType @default(VIDEO)
  sourceType  String              @default("PORTAL_UPLOAD")
  sourcePath  String?
  standaloneSubfolders String[] @default([])
  fileUrl     String?
  externalUrl String?
  thumbnail   String?

  instructor      String?
  department      String?
  level           String?
  durationMinutes Int?
  tags            String[] @default([])

  isRequired Boolean               @default(false)
  status     TrainingPublishStatus @default(DRAFT)
  isActive   Boolean               @default(true)

  categoryId String?
  category   TrainingCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  files      TrainingFile[]
  progress   TrainingProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainingFile {
  id String @id @default(cuid())

  trainingId String
  title      String
  fileUrl    String
  sourcePath String?
  fileType   String?
  fileSize   Int?
  sortOrder  Int     @default(0)
  isPrimary  Boolean @default(false)

  training TrainingItem @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainingSource {
  id String @id @default(cuid())

  name           String
  type           String    @default("SMB")
  basePath       String
  authMode      String    @default("KERBEROS")
  realm         String?
  description    String?   @db.Text
  username       String?
  password       String?
  syncIntervalMinutes Int       @default(5)
  uploadDirectory    String     @default("_PortalUploads")
  isActive       Boolean   @default(true)
  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncError  String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainingProgress {
  id String @id @default(cuid())

  trainingItemId  String
  userId          String?
  directoryUserId String?
  visitorKey      String?

  status              TrainingProgressStatus @default(NOT_STARTED)
  progressPercent     Int                    @default(0)
  lastPositionSeconds Int?
  durationSeconds     Int?
  lastFileUrl         String?
  completedAt         DateTime?
  lastViewedAt        DateTime               @default(now())

  trainingItem  TrainingItem   @relation(fields: [trainingItemId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  directoryUser DirectoryUser? @relation(fields: [directoryUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([trainingItemId, visitorKey])
  @@index([trainingItemId])
  @@index([userId])
  @@index([directoryUserId])
}

model InPersonTraining {
  id String @id @default(cuid())

  title       String
  description String? @db.Text

  categoryId String?
  category   TrainingCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  instructorName      String?
  organizerDepartment String?
  location            String?
  startDate           DateTime
  endDate             DateTime?
  durationHours       Float?
  hasExam             Boolean                @default(false)
  hasCertificate      Boolean                @default(false)
  status              InPersonTrainingStatus @default(PLANNED)

  participants InPersonTrainingParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([startDate])
  @@index([status])
}

model InPersonTrainingParticipant {
  id String @id @default(cuid())

  trainingId      String
  userId          String?
  directoryUserId String?

  displayName       String
  email             String?
  attendanceStatus  InPersonAttendanceStatus @default(REGISTERED)
  score             Float?
  result            InPersonTrainingResult   @default(NO_EXAM)
  certificateNumber String?
  notes             String?                  @db.Text

  training      InPersonTraining @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  user          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  directoryUser DirectoryUser?   @relation(fields: [directoryUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainingId])
  @@index([userId])
  @@index([directoryUserId])
  @@index([attendanceStatus])
  @@index([result])
}

model PollSurvey {
  id String @id @default(cuid())

  type        PollSurveyType
  title       String
  description String?        @db.Text
  category    String?
  tags        String[]       @default([])

  allowMultipleSelection Boolean @default(false)
  anonymous              Boolean @default(false)
  required               Boolean @default(false)
  popupEnforced          Boolean @default(false)
  allowVoteEditing       Boolean @default(false)

  deadline    DateTime?
  publishDate DateTime?
  status      PollSurveyStatus @default(DRAFT)

  targetUserIds     String[] @default([])
  targetDepartments String[] @default([])
  targetAdGroupIds  String[] @default([])

  allowResultViewing    Boolean @default(false)
  allowParticipantCount Boolean @default(true)
  allowLiveResults      Boolean @default(false)
  participantVisibility Boolean @default(false)
  participationMode PollSurveyParticipationMode @default(IDENTIFIED)

  creatorId String?
  creator   User?   @relation("PollSurveyCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  questions PollSurveyQuestion[]
  responses PollSurveyResponse[]
  participations PollSurveyParticipation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([deadline])
  @@index([publishDate])
}

model PollSurveyParticipation {
  id String @id @default(cuid())

  pollSurveyId    String
  userId          String
  directoryUserId String?
  participatedAt  DateTime @default(now())

  pollSurvey    PollSurvey     @relation(fields: [pollSurveyId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  directoryUser DirectoryUser? @relation(fields: [directoryUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pollSurveyId, userId])
  @@index([pollSurveyId])
  @@index([directoryUserId])
}

model PollSurveyQuestion {
  id String @id @default(cuid())

  pollSurveyId String
  type         PollSurveyQuestionType
  title        String
  description  String?                @db.Text
  isRequired   Boolean                @default(false)
  sortOrder    Int                    @default(0)
  settings     Json?

  conditionQuestionId String?
  conditionOperator   String?
  conditionValue      String?

  pollSurvey PollSurvey         @relation(fields: [pollSurveyId], references: [id], onDelete: Cascade)
  options    PollSurveyOption[]
  answers    PollSurveyAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pollSurveyId])
  @@index([type])
}

model PollSurveyOption {
  id String @id @default(cuid())

  questionId String
  label      String
  value      String?
  sortOrder  Int     @default(0)

  question PollSurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  PollSurveyAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([questionId])
}

model PollSurveyResponse {
  id String @id @default(cuid())

  pollSurveyId    String
  userId          String?
  directoryUserId String?

  participantHash  String
  isAnonymous      Boolean                  @default(false)
  status           PollSurveyResponseStatus @default(SUBMITTED)
  draftData        Json?
  timeSpentSeconds Int?
  submittedAt      DateTime?

  pollSurvey    PollSurvey         @relation(fields: [pollSurveyId], references: [id], onDelete: Cascade)
  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  directoryUser DirectoryUser?     @relation(fields: [directoryUserId], references: [id], onDelete: SetNull)
  answers       PollSurveyAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pollSurveyId, participantHash])
  @@index([pollSurveyId])
  @@index([userId])
  @@index([directoryUserId])
  @@index([status])
}

model PollSurveyAnswer {
  id String @id @default(cuid())

  responseId String
  questionId String
  optionId   String?

  optionIds    String[]  @default([])
  textValue    String?   @db.Text
  numberValue  Float?
  dateValue    DateTime?
  booleanValue Boolean?
  matrixValue  Json?

  response PollSurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question PollSurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option   PollSurveyOption?  @relation(fields: [optionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([responseId])
  @@index([questionId])
  @@index([optionId])
}

model Slider {
  id String @id @default(cuid())

  title String
  image String
  url   String?

  sortOrder Int @default(0)

  isActive Boolean @default(true)
}

model Setting {
  id Int @id @default(1)

  companyName String

  logo String?

  favicon String?

  primaryColor String?

  portalBackgroundImageUrl       String?
  portalBackgroundOverlayColor   String?
  portalBackgroundOverlayOpacity Float?
  portalWidgets                  Json?

  footerText String?

  activeDirectoryEnabled         Boolean   @default(false)
  activeDirectoryUrl             String?
  activeDirectoryDomain          String?
  activeDirectoryBaseDn          String?
  activeDirectoryBindDn          String?
  activeDirectoryBindPassword    String?
  activeDirectoryUserSearchBase  String?
  activeDirectoryGroupSearchBase String?
  activeDirectoryTlsServerName String?
  activeDirectoryCaCertificate String? @db.Text
  activeDirectorySyncIntervalMinutes Int       @default(60)
  activeDirectoryLastSyncedAt        DateTime?
  activeDirectoryLastSyncError       String?   @db.Text
  activeDirectoryLastStatus      String?
  activeDirectoryLastError       String?   @db.Text
  activeDirectoryLastCheckedAt   DateTime?

  windowsSsoEnabled Boolean @default(false)
  requirePortalLogin Boolean @default(false)

  trainingMaxUploadSizeMb       Int    @default(2048)
  trainingAllowedFileExtensions String @default("mp4,mkv,webm,mov,avi,pdf,doc,docx,xls,xlsx,ppt,pptx,jpg,jpeg,png,webp,gif,txt,csv,zip,rar,7z")

  requireUserPersonnelCode Boolean               @default(false)
  requireUserBirthDate     Boolean               @default(false)
  requireUserEmail         Boolean               @default(false)
  requireUserMobile        Boolean               @default(false)
  topbarUserDisplayMode    TopbarUserDisplayMode @default(FULL_NAME)
}

enum TopbarUserDisplayMode {
  FULL_NAME
  PERSONNEL_CODE
  USERNAME
}

model SystemStatus {
  id String @id @default(cuid())

  title       String
  status      String
  description String? @db.Text

  icon  String?
  color String?

  checkType           SystemHealthCheckType @default(MANUAL)
  target              String?
  method              String                @default("GET")
  expectedStatusCodes String                @default("200-399")
  expectedKeyword     String?
  intervalSeconds     Int                   @default(300)
  timeoutMs           Int                   @default(5000)
  lastHealthState     SystemHealthState     @default(UNKNOWN)
  lastCheckedAt       DateTime?
  lastResponseTimeMs  Int?
  lastError           String?               @db.Text
  nextCheckAt         DateTime?

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SystemHealthCheckType {
  MANUAL
  HTTP
  TCP
  PING
  SMB
}

enum SystemHealthState {
  UNKNOWN
  UP
  DEGRADED
  DOWN
}

model NotificationSmtpServer {
  id String @id @default(cuid())

  name String
  host String
  port Int

  username String?
  password String?

  senderName  String?
  senderEmail String
  replyTo     String?

  encryption NotificationSmtpEncryption @default(STARTTLS)
  timeoutMs  Int                        @default(10000)
  maxRetry   Int                        @default(3)
  priority   Int                        @default(100)
  isActive   Boolean                    @default(true)
  isPrimary  Boolean                    @default(false)

  lastTestStatus String?
  lastTestError  String?   @db.Text
  lastTestedAt   DateTime?

  emails NotificationEmailQueue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationTemplate {
  id String @id @default(cuid())

  key      String                       @unique
  title    String
  category NotificationTemplateCategory
  status   NotificationTemplateStatus   @default(DRAFT)

  subject   String
  htmlBody  String  @db.Text
  textBody  String? @db.Text
  variables Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emails NotificationEmailQueue[]
  rules  NotificationRule[]
}

model NotificationRule {
  id String @id @default(cuid())

  eventKey    String  @unique
  title       String
  description String? @db.Text
  moduleKey   String?

  portalEnabled Boolean @default(true)
  emailEnabled  Boolean @default(false)
  pushEnabled   Boolean @default(false)
  smsEnabled    Boolean @default(false)
  teamsEnabled  Boolean @default(false)

  emailTemplateId String?
  priority        Int     @default(100)
  isActive        Boolean @default(true)

  emailTemplate NotificationTemplate? @relation(fields: [emailTemplateId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationEmailQueue {
  id String @id @default(cuid())

  recipientEmail String
  recipientName  String?
  subject        String
  htmlBody       String  @db.Text
  textBody       String? @db.Text

  templateId   String?
  smtpServerId String?

  status     NotificationQueueStatus @default(PENDING)
  retryCount Int                     @default(0)
  maxRetry   Int                     @default(3)
  priority   Int                     @default(100)

  scheduledAt DateTime?
  sendingAt   DateTime?
  sentAt      DateTime?
  failedAt    DateTime?
  cancelledAt DateTime?

  messageId     String?
  failureReason String? @db.Text
  metadata      Json?

  template   NotificationTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  smtpServer NotificationSmtpServer? @relation(fields: [smtpServerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BackupJob {
  id String @id @default(cuid())

  type   BackupType   @default(FULL)
  status BackupStatus @default(PENDING)

  fileName String?
  filePath String?
  fileSize BigInt?

  includeDatabase Boolean @default(true)
  includeUploads  Boolean @default(true)

  requestedByUserId String?
  notifyEmail       String?

  startedAt  DateTime?
  finishedAt DateTime?
  error      String?   @db.Text
  metadata   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restoreJobs BackupRestoreJob[]
}

model BackupRestoreJob {
  id String @id @default(cuid())

  backupId          String
  emergencyBackupId String?
  status            BackupRestoreStatus @default(PENDING)

  restoreDatabase Boolean @default(true)
  restoreUploads  Boolean @default(true)

  startedAt  DateTime?
  finishedAt DateTime?
  error      String?   @db.Text
  metadata   Json?

  backup BackupJob @relation(fields: [backupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BackupSetting {
  id Int @id @default(1)

  autoEnabled       Boolean                 @default(false)
  frequency         BackupScheduleFrequency @default(DAILY)
  scheduleTime      String                  @default("02:00")
  weeklyDayOfWeek   Int                     @default(6)
  monthlyDayOfMonth Int                     @default(1)
  type              BackupType              @default(FULL)
  includeDatabase   Boolean                 @default(true)
  includeUploads    Boolean                 @default(true)
  retentionCount    Int                     @default(10)
  notifyEmails      String?

  lastRunAt DateTime?
  nextRunAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum NotificationSmtpEncryption {
  NONE
  SSL
  TLS
  STARTTLS
}

enum NotificationQueueStatus {
  PENDING
  SENDING
  SENT
  FAILED
  RETRY
  CANCELLED
}

enum NotificationTemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NotificationTemplateCategory {
  WELCOME
  PASSWORD_RESET
  ANNOUNCEMENTS
  TRAINING
  CALENDAR
  MEETINGS
  POLLS
  SURVEYS
  CEO_MESSAGES
  ASSETS
  MAINTENANCE
  INVENTORY
  LICENSES
  WARRANTY
  SYSTEM_ALERTS
  BACKUPS
  GENERAL
}

enum BackupType {
  DATABASE
  FILES
  FULL
}

enum BackupStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  DELETED
}

enum BackupRestoreStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum BackupScheduleFrequency {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}
