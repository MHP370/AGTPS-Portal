generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  ACTIVE
  MAINTENANCE
  OFFLINE
  DISABLED
}

enum NetworkType {
  INTERNET
  INTRANET
  VPN
}

enum MeetingStatus {
  SCHEDULED
  CANCELLED
  DONE
}

enum MeetingVisibility {
  PUBLIC
  PRIVATE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum NotificationType {
  MEETING_INVITE
  MEETING_UPDATE
  REMINDER
  TASK
}

enum DirectorySource {
  INTERNAL
  ACTIVE_DIRECTORY
}

enum TrainingContentType {
  VIDEO
  PDF
  DOCUMENT
  SPREADSHEET
  PRESENTATION
  IMAGE
  LINK
  ATTACHMENT
}

enum TrainingPublishStatus {
  NEEDS_REVIEW
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  email       String   @unique
  password    String

  firstName   String?
  lastName    String?

  isActive    Boolean  @default(true)

  roles        UserRole[]
  organizedMeetings Meeting[] @relation("MeetingOrganizer")
  meetingParticipants MeetingParticipant[]
  notes        PortalNote[]
  reminders    PortalReminder[]
  tasks        PortalTask[]
  downloads    PortalDownload[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  title       String

  users       UserRole[]
  permissions RolePermission[]
  directoryGroups DirectoryGroupRole[]

  createdAt   DateTime @default(now())
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  title       String

  roles       RolePermission[]
}

model DirectoryUser {
  id          String @id @default(cuid())
  username    String @unique
  displayName String
  email       String?
  department  String?
  title       String?
  source      DirectorySource @default(INTERNAL)
  isActive    Boolean @default(true)

  groupMemberships DirectoryGroupMember[]
  organizedMeetings Meeting[] @relation("DirectoryMeetingOrganizer")
  meetingParticipants MeetingParticipant[]
  notifications PortalNotification[]
  pushSubscriptions PushSubscription[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DirectoryGroup {
  id          String @id @default(cuid())
  name        String @unique
  title       String
  description String?
  source      DirectorySource @default(INTERNAL)
  isActive    Boolean @default(true)

  members     DirectoryGroupMember[]
  roles       DirectoryGroupRole[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DirectoryGroupMember {
  groupId String
  userId  String

  group DirectoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  DirectoryUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

model DirectoryGroupRole {
  groupId String
  roleId  String

  group DirectoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role  Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([groupId, roleId])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Site {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String

  description String?
  baseUrl     String?
  ipRange     String?
  address     String?
  phone       String?
  email       String?

  latitude    Float?
  longitude   Float?

  logo        String?
  image       String?
  color       String?

  sortOrder   Int      @default(0)

  isActive    Boolean  @default(true)

  applicationSites ApplicationSite[]
  news             News[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApplicationCategory {
  id          String   @id @default(cuid())

  name        String
  slug        String   @unique

  icon        String?
  color       String?
  description String?

  sortOrder   Int      @default(0)

  isActive    Boolean  @default(true)

  applications Application[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Application {
  id          String   @id @default(cuid())

  key         String   @unique
  slug        String   @unique

  title       String
  description String?

  icon        String?

  color       String?

  status      ApplicationStatus @default(ACTIVE)

  networkType NetworkType @default(INTRANET)

  version     String?

  owner       String?

  supportDepartment String?

  guideUrl    String?

  isFeatured  Boolean @default(false)

  isNew       Boolean @default(false)

  openInNewTab Boolean @default(true)

  sortOrder   Int @default(0)

  isActive    Boolean @default(true)

  categoryId  String
  category    ApplicationCategory @relation(fields: [categoryId], references: [id])

  sites       ApplicationSite[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApplicationSite {
  id            String @id @default(cuid())

  applicationId String
  siteId        String

  url           String

  isActive      Boolean @default(true)

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  site          Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([applicationId, siteId])
}

model News {
  id          String   @id @default(cuid())
  title       String
  body        String   @db.Text
  category    String?
  attachmentUrl String?
  image       String?
  published   Boolean  @default(true)

  siteId      String
  site        Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  body        String   @db.Text
  category    String?
  attachmentUrl String?

  startDate   DateTime
  endDate     DateTime?

  priority    Int      @default(1)

  published   Boolean  @default(true)

  createdAt   DateTime @default(now())
}

model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String? @db.Text
  location    String?

  startAt     DateTime
  endAt       DateTime?

  status      MeetingStatus @default(SCHEDULED)
  visibility  MeetingVisibility @default(PUBLIC)
  isPublished Boolean @default(true)

  organizerId String?
  organizer   User? @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)
  organizerDirectoryUserId String?
  organizerDirectoryUser DirectoryUser? @relation("DirectoryMeetingOrganizer", fields: [organizerDirectoryUserId], references: [id], onDelete: SetNull)

  participants MeetingParticipant[]
  notifications PortalNotification[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MeetingParticipant {
  id          String @id @default(cuid())
  meetingId   String
  userId      String?
  directoryUserId String?

  displayName String
  email       String?

  notificationSent Boolean @default(false)
  responseStatus   String?

  meeting     Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user        User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  directoryUser DirectoryUser? @relation(fields: [directoryUserId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
}

model PortalNotification {
  id          String @id @default(cuid())
  type        NotificationType
  title       String
  body        String? @db.Text

  recipientDirectoryUserId String?
  recipientEmail String?

  meetingId   String?
  scheduledAt DateTime?
  sentAt      DateTime?
  readAt      DateTime?

  recipientDirectoryUser DirectoryUser? @relation(fields: [recipientDirectoryUserId], references: [id], onDelete: SetNull)
  meeting     Meeting? @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model PushSubscription {
  id          String @id @default(cuid())
  endpoint    String @unique @db.Text
  p256dh      String
  auth        String
  userAgent   String?

  recipientDirectoryUserId String?
  recipientEmail String?

  recipientDirectoryUser DirectoryUser? @relation(fields: [recipientDirectoryUserId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PortalNote {
  id          String @id @default(cuid())
  ownerId     String?
  title       String
  body        String @db.Text
  color       String?
  isPinned    Boolean @default(false)

  owner       User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PortalReminder {
  id          String @id @default(cuid())
  ownerId     String?
  title       String
  description String? @db.Text
  remindAt    DateTime
  notifyBeforeMinutes Int?
  completed   Boolean @default(false)

  owner       User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PortalTask {
  id          String @id @default(cuid())
  ownerId     String?
  title       String
  description String? @db.Text
  dueDate     DateTime?
  notifyBeforeMinutes Int?
  status      TaskStatus @default(TODO)
  priority    Int @default(1)

  owner       User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PortalDownload {
  id          String @id @default(cuid())
  title       String
  description String? @db.Text
  version     String?
  fileUrl     String
  category    String?
  icon        String?
  color       String?
  sortOrder   Int @default(0)
  isActive    Boolean @default(true)

  ownerId     String?
  owner       User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PortalModule {
  id          String @id @default(cuid())

  key         String @unique
  title       String
  description String? @db.Text

  icon        String?
  route       String?
  permission  String?

  isCore      Boolean @default(false)
  isInstalled Boolean @default(true)
  isEnabled   Boolean @default(true)

  sortOrder   Int @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TrainingCategory {
  id          String @id @default(cuid())

  name        String
  slug        String @unique
  description String? @db.Text
  color       String?
  icon        String?
  sortOrder   Int @default(0)
  isActive    Boolean @default(true)

  trainings   TrainingItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TrainingItem {
  id          String @id @default(cuid())

  title       String
  slug        String @unique
  description String? @db.Text

  contentType TrainingContentType @default(VIDEO)
  sourceType  String @default("PORTAL_UPLOAD")
  sourcePath  String?
  fileUrl     String?
  externalUrl String?
  thumbnail   String?

  instructor  String?
  department  String?
  level       String?
  durationMinutes Int?
  tags        String[] @default([])

  isRequired  Boolean @default(false)
  status      TrainingPublishStatus @default(DRAFT)
  isActive    Boolean @default(true)

  categoryId  String?
  category    TrainingCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  files       TrainingFile[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TrainingFile {
  id          String @id @default(cuid())

  trainingId  String
  title       String
  fileUrl     String
  fileType    String?
  fileSize    Int?
  sortOrder   Int @default(0)
  isPrimary   Boolean @default(false)

  training    TrainingItem @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TrainingSource {
  id          String @id @default(cuid())

  name        String
  type        String @default("SMB")
  basePath    String
  description String? @db.Text
  username    String?
  password    String?
  isActive    Boolean @default(true)
  lastSyncAt  DateTime?
  lastSyncStatus String?
  lastSyncError String? @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Slider {
  id          String   @id @default(cuid())

  title       String
  image       String
  url         String?

  sortOrder   Int      @default(0)

  isActive    Boolean  @default(true)
}

model Setting {
  id           Int    @id @default(1)

  companyName  String

  logo         String?

  primaryColor String?

  portalBackgroundImageUrl String?
  portalBackgroundOverlayColor String?
  portalBackgroundOverlayOpacity Float?
  portalWidgets Json?

  footerText   String?

  activeDirectoryEnabled Boolean @default(false)
  activeDirectoryUrl String?
  activeDirectoryDomain String?
  activeDirectoryBaseDn String?
  activeDirectoryBindDn String?
  activeDirectoryBindPassword String?
  activeDirectoryUserSearchBase String?
  activeDirectoryGroupSearchBase String?
  activeDirectoryLastStatus String?
  activeDirectoryLastError String? @db.Text
  activeDirectoryLastCheckedAt DateTime?

  trainingMaxUploadSizeMb Int @default(2048)
  trainingAllowedFileExtensions String @default("mp4,mkv,webm,mov,avi,pdf,doc,docx,xls,xlsx,ppt,pptx,jpg,jpeg,png,webp,gif,txt,csv,zip,rar,7z")
}

model SystemStatus {
  id          String @id @default(cuid())

  title       String
  status      String
  description String? @db.Text

  icon        String?
  color       String?

  sortOrder   Int @default(0)
  isActive    Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
