generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  ACTIVE
  MAINTENANCE
  OFFLINE
  DISABLED
}

enum NetworkType {
  INTERNET
  INTRANET
  VPN
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  email       String   @unique
  password    String

  firstName   String?
  lastName    String?

  isActive    Boolean  @default(true)

  roles        UserRole[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  title       String

  users       UserRole[]
  permissions RolePermission[]

  createdAt   DateTime @default(now())
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  title       String

  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Site {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String

  description String?
  address     String?
  phone       String?
  email       String?

  latitude    Float?
  longitude   Float?

  logo        String?
  image       String?
  color       String?

  sortOrder   Int      @default(0)

  isActive    Boolean  @default(true)

  applicationSites ApplicationSite[]
  news             News[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApplicationCategory {
  id          String   @id @default(cuid())

  name        String
  slug        String   @unique

  icon        String?
  color       String?
  description String?

  sortOrder   Int      @default(0)

  isActive    Boolean  @default(true)

  applications Application[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Application {
  id          String   @id @default(cuid())

  key         String   @unique
  slug        String   @unique

  title       String
  description String?

  icon        String?

  color       String?

  status      ApplicationStatus @default(ACTIVE)

  networkType NetworkType @default(INTRANET)

  version     String?

  owner       String?

  supportDepartment String?

  guideUrl    String?

  isFeatured  Boolean @default(false)

  isNew       Boolean @default(false)

  openInNewTab Boolean @default(true)

  sortOrder   Int @default(0)

  isActive    Boolean @default(true)

  categoryId  String
  category    ApplicationCategory @relation(fields: [categoryId], references: [id])

  sites       ApplicationSite[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApplicationSite {
  id            String @id @default(cuid())

  applicationId String
  siteId        String

  url           String

  isActive      Boolean @default(true)

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  site          Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([applicationId, siteId])
}

model News {
  id          String   @id @default(cuid())
  title       String
  body        String   @db.Text
  image       String?
  published   Boolean  @default(true)

  siteId      String
  site        Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  body        String   @db.Text

  startDate   DateTime
  endDate     DateTime?

  priority    Int      @default(1)

  published   Boolean  @default(true)

  createdAt   DateTime @default(now())
}

model Slider {
  id          String   @id @default(cuid())

  title       String
  image       String
  url         String?

  sortOrder   Int      @default(0)

  isActive    Boolean  @default(true)
}

model Setting {
  id           Int    @id @default(1)

  companyName  String

  logo         String?

  primaryColor String?

  footerText   String?
}
