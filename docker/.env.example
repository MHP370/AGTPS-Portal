NGINX_PORT=80

POSTGRES_DB=agtps_portal
POSTGRES_USER=agtps
POSTGRES_PASSWORD=change-this-password

JWT_SECRET=change-this-long-random-secret
DIRECT_COMMUNICATION_ENCRYPTION_KEY=change-this-separate-long-random-secret
DIRECT_COMMUNICATION_MESSAGING_ENABLED=true

VAPID_PUBLIC_KEY=change-this-public-key
VAPID_PRIVATE_KEY=change-this-private-key
VAPID_SUBJECT=mailto:admin@agtps.local

# Use /api when the portal is opened through the nginx container.
NEXT_PUBLIC_API_URL=/api
PORTAL_URL=http://localhost

# Host path that contains mounted SMB shares.
# Inside the API container it will be available as /mnt/file-shares.
FILE_SHARES_ROOT=/srv/agtps/file-shares

# Active Directory DNS used by the API container.
AD_DNS_SERVER=172.16.16.5
AD_DNS_SEARCH_DOMAIN=agtps.net
KERBEROS_SERVICE_PRINCIPAL=HTTP/portal.agtps.net@AGTPS.NET
KERBEROS_SYNC_USERNAME=svc-agtps-portal
# Generate with: openssl rand -hex 32
SSO_SHARED_SECRET=replace-with-a-random-64-character-hex-value
